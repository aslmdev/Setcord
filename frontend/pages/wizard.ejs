<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setcord — Server Setup</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #06060f;
            --card: #0d0d1f;
            --purple: #7c3aed;
            --purple-light: #a78bfa;
            --purple-glow: rgba(124, 58, 237, 0.3);
            --green: #10b981;
            --border: #1c1c3a;
            --text: #e8e8f0;
            --muted: #5a5a8a;
            --font: 'DM Sans', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* ---- Animated background ---- */
        .wizard-bg {
            position: fixed;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            animation: float 8s ease-in-out infinite;
        }

        .glow-1 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.4) 0%, transparent 70%);
            top: -200px;
            left: -100px;
            animation-delay: 0s;
        }

        .glow-2 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.2) 0%, transparent 70%);
            bottom: -150px;
            right: -100px;
            animation-delay: -4s;
        }

        .glow-3 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, transparent 70%);
            top: 50%;
            right: 20%;
            animation-delay: -2s;
        }

        @keyframes float {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            33% {
                transform: translate(30px, -20px) scale(1.05);
            }

            66% {
                transform: translate(-20px, 15px) scale(0.95);
            }
        }

        /* ---- Main wizard card ---- */
        .wizard-wrap {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 620px;
            padding: 20px;
        }

        .wizard-card {
            background: rgba(13, 13, 31, 0.9);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 24px;
            padding: 0;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(124, 58, 237, 0.1);
            overflow: hidden;
        }

        /* ---- Progress bar ---- */
        .progress-track {
            height: 3px;
            background: rgba(255, 255, 255, 0.05);
            width: 100%;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--purple), var(--purple-light));
            border-radius: 2px;
            transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* ---- Card inner ---- */
        .wizard-inner {
            padding: 36px 40px 32px;
        }

        /* ---- Step dots ---- */
        .step-dots {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 28px;
            justify-content: center;
        }

        .step-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .step-dot.active {
            background: var(--purple);
            box-shadow: 0 0 8px var(--purple-glow);
            width: 22px;
            border-radius: 4px;
        }

        .step-dot.done {
            background: var(--green);
        }

        /* ---- Steps ---- */
        .step {
            display: none;
            animation: stepIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .step.active {
            display: block;
        }

        @keyframes stepIn {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.98);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* ---- Step header ---- */
        .step-icon {
            font-size: 44px;
            margin-bottom: 12px;
            display: block;
            animation: iconPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
        }

        @keyframes iconPop {
            from {
                transform: scale(0.5) rotate(-10deg);
                opacity: 0;
            }

            to {
                transform: scale(1) rotate(0);
                opacity: 1;
            }
        }

        .step-title {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .step-subtitle {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 28px;
            line-height: 1.6;
        }

        /* ---- Option cards ---- */
        .options-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 28px;
        }

        .options-grid.three {
            grid-template-columns: repeat(3, 1fr);
        }

        .option-card {
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid rgba(255, 255, 255, 0.06);
            border-radius: 14px;
            padding: 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: center;
            user-select: none;
        }

        .option-card:hover {
            border-color: rgba(124, 58, 237, 0.4);
            background: rgba(124, 58, 237, 0.06);
            transform: translateY(-2px);
        }

        .option-card.selected {
            border-color: var(--purple);
            background: rgba(124, 58, 237, 0.12);
            box-shadow: 0 0 0 1px var(--purple), 0 4px 20px rgba(124, 58, 237, 0.2);
        }

        .option-card.selected .option-check {
            opacity: 1;
        }

        .option-emoji {
            font-size: 28px;
            margin-bottom: 8px;
            display: block;
        }

        .option-name {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .option-desc {
            font-size: 11px;
            color: var(--muted);
            line-height: 1.4;
        }

        .option-check {
            width: 20px;
            height: 20px;
            background: var(--purple);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 8px auto 0;
            opacity: 0;
            transition: opacity 0.2s;
            font-size: 11px;
        }

        /* Style preview */
        .style-preview {
            margin-top: 8px;
            font-size: 10px;
            color: rgba(167, 139, 250, 0.7);
            font-family: monospace;
            line-height: 1.6;
        }

        /* ---- Form inputs ---- */
        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 14px;
            font-family: var(--font);
            padding: 11px 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-input:focus {
            border-color: var(--purple);
        }

        .form-input::placeholder {
            color: var(--muted);
        }

        textarea.form-input {
            min-height: 80px;
            resize: vertical;
        }

        /* ---- Feature toggles ---- */
        .feature-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 28px;
        }

        .feature-toggle {
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }

        .feature-toggle:hover {
            border-color: rgba(124, 58, 237, 0.3);
        }

        .feature-toggle.on {
            border-color: var(--purple);
            background: rgba(124, 58, 237, 0.1);
        }

        .feature-icon-wrap {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
            transition: background 0.2s;
        }

        .feature-toggle.on .feature-icon-wrap {
            background: rgba(124, 58, 237, 0.2);
        }

        .feature-text {
            flex: 1;
        }

        .feature-name {
            font-size: 13px;
            font-weight: 600;
        }

        .feature-hint {
            font-size: 11px;
            color: var(--muted);
        }

        .toggle-pill {
            width: 36px;
            height: 20px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            position: relative;
            transition: background 0.2s;
            flex-shrink: 0;
        }

        .feature-toggle.on .toggle-pill {
            background: var(--purple);
        }

        .toggle-pill::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .feature-toggle.on .toggle-pill::after {
            transform: translateX(16px);
        }

        /* ---- Navigation buttons ---- */
        .wizard-nav {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .btn-back {
            padding: 11px 22px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--muted);
            font-size: 14px;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-back:hover {
            color: var(--text);
            border-color: var(--muted);
        }

        .btn-next {
            flex: 1;
            padding: 12px 24px;
            background: linear-gradient(135deg, var(--purple), #9333ea);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 14px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-next:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(124, 58, 237, 0.5);
        }

        .btn-next:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

        .btn-skip {
            font-size: 12px;
            color: var(--muted);
            background: none;
            border: none;
            cursor: pointer;
            font-family: var(--font);
            padding: 4px 8px;
            display: block;
            text-align: center;
            margin-top: 10px;
            transition: color 0.2s;
        }

        .btn-skip:hover {
            color: var(--text);
        }

        /* ---- Server info header ---- */
        .server-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px;
            padding: 14px 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 14px;
        }

        .server-avatar {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            overflow: hidden;
            background: var(--purple);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 800;
            flex-shrink: 0;
        }

        .server-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .server-info-text h3 {
            font-size: 15px;
            font-weight: 700;
        }

        .server-info-text p {
            font-size: 12px;
            color: var(--muted);
            margin-top: 2px;
        }

        .server-badge {
            margin-left: auto;
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 11px;
            color: var(--green);
            font-weight: 700;
        }

        /* ---- AI Loading step ---- */
        .ai-loading-wrap {
            text-align: center;
            padding: 20px 0 10px;
        }

        .ai-orb {
            width: 80px;
            height: 80px;
            margin: 0 auto 24px;
            position: relative;
        }

        .ai-orb-inner {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--purple), #9333ea);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            animation: aiPulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 40px rgba(124, 58, 237, 0.5);
        }

        @keyframes aiPulse {

            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
            }

            50% {
                transform: scale(1.08);
                box-shadow: 0 0 60px rgba(124, 58, 237, 0.7);
            }
        }

        .ai-orb-ring {
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            border: 2px solid rgba(167, 139, 250, 0.3);
            animation: ringExpand 2s ease-out infinite;
        }

        .ai-orb-ring:nth-child(2) {
            animation-delay: -1s;
            inset: -20px;
            opacity: 0.5;
        }

        @keyframes ringExpand {
            from {
                transform: scale(0.8);
                opacity: 0.6;
            }

            to {
                transform: scale(1.4);
                opacity: 0;
            }
        }

        .ai-status {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .ai-substatus {
            font-size: 13px;
            color: var(--muted);
            animation: textFade 2s ease-in-out infinite;
        }

        @keyframes textFade {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        .ai-dots {
            display: inline-flex;
            gap: 4px;
            margin-left: 4px;
        }

        .ai-dot {
            width: 5px;
            height: 5px;
            background: var(--purple-light);
            border-radius: 50%;
            animation: dotBounce 1.2s ease-in-out infinite;
        }

        .ai-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .ai-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes dotBounce {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-5px);
            }
        }

        /* ---- Preview step ---- */
        .preview-split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
            max-height: 260px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }

        .preview-section h4 {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .preview-cat {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--muted);
            letter-spacing: 0.5px;
            padding: 4px 0;
        }

        .preview-ch {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 8px;
            border-radius: 5px;
            font-size: 12px;
            color: rgba(232, 232, 240, 0.7);
            cursor: pointer;
            transition: background 0.1s;
        }

        .preview-ch:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text);
        }

        .preview-ch input {
            background: none;
            border: none;
            outline: none;
            color: inherit;
            font-family: var(--font);
            font-size: 12px;
            width: 100%;
        }

        .preview-role {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 8px;
            border-radius: 5px;
            font-size: 12px;
            cursor: pointer;
        }

        .preview-role:hover {
            background: rgba(255, 255, 255, 0.04);
        }

        .role-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* Debug panel */
        .debug-panel {
            margin-top: 12px;
            border: 1px solid rgba(245, 158, 11, 0.2);
            border-radius: 8px;
            overflow: hidden;
        }

        .debug-header {
            background: rgba(245, 158, 11, 0.08);
            padding: 8px 12px;
            font-size: 11px;
            font-weight: 700;
            color: #fbbf24;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            user-select: none;
        }

        .debug-body {
            display: none;
            padding: 10px 12px;
            font-size: 10px;
            font-family: monospace;
            color: rgba(255, 255, 255, 0.5);
            max-height: 150px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-all;
            background: rgba(0, 0, 0, 0.2);
        }

        .debug-body.show {
            display: block;
        }

        /* ---- Applying step ---- */
        .apply-log {
            max-height: 200px;
            overflow-y: auto;
            margin-bottom: 16px;
            display: flex;
            flex-direction: column;
            gap: 5px;
            scrollbar-width: thin;
        }

        .apply-log-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: 8px;
            font-size: 12px;
            animation: slideIn 0.2s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-10px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .apply-log-item.ok {
            background: rgba(16, 185, 129, 0.08);
            color: #34d399;
        }

        .apply-log-item.fail {
            background: rgba(239, 68, 68, 0.08);
            color: #f87171;
        }

        .apply-log-item.pending {
            background: rgba(167, 139, 250, 0.08);
            color: #a78bfa;
        }

        .apply-progress-bar {
            height: 4px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 2px;
            margin-bottom: 16px;
            overflow: hidden;
        }

        .apply-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--purple), var(--green));
            border-radius: 2px;
            transition: width 0.3s ease;
        }

        /* ---- Done step ---- */
        .done-celebration {
            text-align: center;
            padding: 10px 0;
        }

        .done-icon-wrap {
            width: 90px;
            height: 90px;
            margin: 0 auto 20px;
            background: linear-gradient(135deg, var(--purple), #9333ea);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 42px;
            box-shadow: 0 0 50px rgba(124, 58, 237, 0.5);
            animation: donePop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
        }

        @keyframes donePop {
            from {
                transform: scale(0) rotate(-20deg);
            }

            to {
                transform: scale(1) rotate(0);
            }
        }

        .done-stats {
            display: flex;
            gap: 12px;
            margin: 20px 0;
        }

        .done-stat {
            flex: 1;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px;
            text-align: center;
        }

        .done-stat-num {
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--purple-light), var(--green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .done-stat-label {
            font-size: 11px;
            color: var(--muted);
            margin-top: 3px;
        }

        .btn-go-dashboard {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--purple), #9333ea);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 15px;
            font-weight: 700;
            font-family: var(--font);
            cursor: pointer;
            box-shadow: 0 6px 30px rgba(124, 58, 237, 0.4);
            transition: all 0.2s;
        }

        .btn-go-dashboard:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(124, 58, 237, 0.6);
        }

        /* Confetti particles */
        .confetti-container {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 100;
        }

        .confetti-piece {
            position: absolute;
            width: 8px;
            height: 8px;
            border-radius: 2px;
            animation: confettiFall 3s ease-in forwards;
        }

        @keyframes confettiFall {
            0% {
                transform: translateY(-20px) rotate(0deg);
                opacity: 1;
            }

            100% {
                transform: translateY(110vh) rotate(720deg);
                opacity: 0;
            }
        }
    </style>
</head>

<body>

    <div class="wizard-bg">
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>
        <div class="glow glow-3"></div>
    </div>

    <div class="wizard-wrap">
        <div class="wizard-card">
            <div class="progress-track">
                <div class="progress-fill" id="progress-fill" style="width:0%"></div>
            </div>
            <div class="wizard-inner">

                <!-- Step dots -->
                <div class="step-dots" id="step-dots"></div>

                <!-- ════ STEP 1: Welcome ════ -->
                <div class="step active" data-step="1">
                    <span class="step-icon">✨</span>
                    <h2 class="step-title">Welcome to Setcord!</h2>
                    <p class="step-subtitle">Let's build your server structure from scratch. This takes about 60
                        seconds.</p>

                    <div class="server-header">
                        <div class="server-avatar">
                            <% if (guild.icon) { %>
                                <img src="<%= guild.icon %>" alt="">
                                <% } else { %>
                                    <%= guild.name.charAt(0).toUpperCase() %>
                                        <% } %>
                        </div>
                        <div class="server-info-text">
                            <h3>
                                <%= guild.name %>
                            </h3>
                            <p>Ready for setup</p>
                        </div>
                        <span class="server-badge">🤖 Bot Active</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Server Name</label>
                        <input type="text" class="form-input" id="ans-name" value="<%= guild.name %>" maxlength="100"
                            placeholder="Your server name">
                    </div>
                    <div class="form-group" style="margin-bottom:0">
                        <label class="form-label">Short Description <span
                                style="color:var(--muted);font-weight:400;text-transform:none;">(optional)</span></label>
                        <textarea class="form-input" id="ans-description"
                            placeholder="What is this server about? This helps AI generate better content..."
                            maxlength="200"></textarea>
                    </div>

                    <div class="wizard-nav" style="margin-top:24px;">
                        <button class="btn-next" onclick="goNext()" id="btn-1-next">
                            Let's go <span>→</span>
                        </button>
                    </div>
                    <button class="btn-skip" onclick="skipWizard()">Skip setup — I'll configure manually</button>
                </div>

                <!-- ════ STEP 2: Server Type ════ -->
                <div class="step" data-step="2">
                    <span class="step-icon">🎯</span>
                    <h2 class="step-title">What kind of server is this?</h2>
                    <p class="step-subtitle">This helps AI understand your server's purpose.</p>

                    <div class="options-grid three" id="type-options">
                        <div class="option-card" onclick="selectOption('type','gaming',this)">
                            <span class="option-emoji">🎮</span>
                            <div class="option-name">Gaming</div>
                            <div class="option-desc">Games, esports, tournaments</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('type','community',this)">
                            <span class="option-emoji">🌍</span>
                            <div class="option-name">Community</div>
                            <div class="option-desc">Social hangout, friends</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('type','business',this)">
                            <span class="option-emoji">💼</span>
                            <div class="option-name">Business</div>
                            <div class="option-desc">Work, teams, projects</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('type','education',this)">
                            <span class="option-emoji">📚</span>
                            <div class="option-name">Education</div>
                            <div class="option-desc">Study groups, courses</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('type','creative',this)">
                            <span class="option-emoji">🎨</span>
                            <div class="option-name">Creative</div>
                            <div class="option-desc">Art, music, design</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('type','other',this)">
                            <span class="option-emoji">✨</span>
                            <div class="option-name">Other</div>
                            <div class="option-desc">Something unique</div>
                            <div class="option-check">✓</div>
                        </div>
                    </div>

                    <div class="wizard-nav">
                        <button class="btn-back" onclick="goBack()">← Back</button>
                        <button class="btn-next" onclick="goNext()" id="btn-2-next" disabled>
                            Continue →
                        </button>
                    </div>
                </div>

                <!-- ════ STEP 3: Channel Style ════ -->
                <div class="step" data-step="3">
                    <span class="step-icon">🎨</span>
                    <h2 class="step-title">How should channels look?</h2>
                    <p class="step-subtitle">Pick a naming style. AI will use this for all channels.</p>

                    <div class="options-grid">
                        <div class="option-card" onclick="selectOption('style','modern',this)">
                            <span class="option-emoji">⚡</span>
                            <div class="option-name">Modern</div>
                            <div class="style-preview">📁 GENERAL<br># general-chat<br># announcements<br>🔊
                                voice-lounge</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('style','emoji',this)">
                            <span class="option-emoji">🌈</span>
                            <div class="option-name">Emoji Style</div>
                            <div class="style-preview">📁 GENERAL<br>💬・general<br>📢・announcements<br>🔊・voice-lounge
                            </div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('style','official',this)">
                            <span class="option-emoji">🏛️</span>
                            <div class="option-name">Official</div>
                            <div class="style-preview">📁 GENERAL<br># General Discussion<br># Announcements<br>🔊 Voice
                                Lounge</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('style','arabic',this)">
                            <span class="option-emoji">🌙</span>
                            <div class="option-name">Arabic</div>
                            <div class="style-preview" dir="rtl">📁 عام<br># عام-الدردشة<br># الإعلانات<br>🔊 استراحة
                                صوتية</div>
                            <div class="option-check">✓</div>
                        </div>
                    </div>

                    <div class="wizard-nav">
                        <button class="btn-back" onclick="goBack()">← Back</button>
                        <button class="btn-next" onclick="goNext()" id="btn-3-next" disabled>
                            Continue →
                        </button>
                    </div>
                </div>

                <!-- ════ STEP 4: Features ════ -->
                <div class="step" data-step="4">
                    <span class="step-icon">🛠️</span>
                    <h2 class="step-title">Which features do you need?</h2>
                    <p class="step-subtitle">Toggle what you want. You can always add more later.</p>

                    <div class="feature-grid">
                        <div class="feature-toggle on" onclick="toggleFeature('welcome',this)" data-feature="welcome">
                            <div class="feature-icon-wrap">👋</div>
                            <div class="feature-text">
                                <div class="feature-name">Welcome</div>
                                <div class="feature-hint">Rules & info channels</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                        <div class="feature-toggle on" onclick="toggleFeature('logs',this)" data-feature="logs">
                            <div class="feature-icon-wrap">📋</div>
                            <div class="feature-text">
                                <div class="feature-name">Server Logs</div>
                                <div class="feature-hint">Moderation logs</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                        <div class="feature-toggle" onclick="toggleFeature('afk',this)" data-feature="afk">
                            <div class="feature-icon-wrap">😴</div>
                            <div class="feature-text">
                                <div class="feature-name">AFK Channel</div>
                                <div class="feature-hint">Voice AFK room</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                        <div class="feature-toggle" onclick="toggleFeature('tickets',this)" data-feature="tickets">
                            <div class="feature-icon-wrap">🎫</div>
                            <div class="feature-text">
                                <div class="feature-name">Tickets</div>
                                <div class="feature-hint">Support system</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                        <div class="feature-toggle" onclick="toggleFeature('media',this)" data-feature="media">
                            <div class="feature-icon-wrap">📸</div>
                            <div class="feature-text">
                                <div class="feature-name">Media</div>
                                <div class="feature-hint">Memes & screenshots</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                        <div class="feature-toggle" onclick="toggleFeature('bot',this)" data-feature="bot">
                            <div class="feature-icon-wrap">🤖</div>
                            <div class="feature-text">
                                <div class="feature-name">Bot Commands</div>
                                <div class="feature-hint">Dedicated bot channel</div>
                            </div>
                            <div class="toggle-pill"></div>
                        </div>
                    </div>

                    <div class="wizard-nav">
                        <button class="btn-back" onclick="goBack()">← Back</button>
                        <button class="btn-next" onclick="goNext()">Continue →</button>
                    </div>
                </div>

                <!-- ════ STEP 5: Roles ════ -->
                <div class="step" data-step="5">
                    <span class="step-icon">🛡️</span>
                    <h2 class="step-title">How complex should roles be?</h2>
                    <p class="step-subtitle">AI will generate a role hierarchy to match.</p>

                    <div class="options-grid">
                        <div class="option-card" onclick="selectOption('roles','simple',this)">
                            <span class="option-emoji">🌱</span>
                            <div class="option-name">Simple</div>
                            <div class="option-desc">3-5 basic roles: Admin, Mod, Member</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('roles','standard',this)">
                            <span class="option-emoji">⚖️</span>
                            <div class="option-name">Standard</div>
                            <div class="option-desc">8-12 roles with hierarchy & colors</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('roles','detailed',this)">
                            <span class="option-emoji">🏆</span>
                            <div class="option-name">Detailed</div>
                            <div class="option-desc">15+ roles: full staff + member levels</div>
                            <div class="option-check">✓</div>
                        </div>
                        <div class="option-card" onclick="selectOption('roles','none',this)">
                            <span class="option-emoji">🚫</span>
                            <div class="option-name">No Roles</div>
                            <div class="option-desc">Only channels, skip roles</div>
                            <div class="option-check">✓</div>
                        </div>
                    </div>

                    <div class="wizard-nav">
                        <button class="btn-back" onclick="goBack()">← Back</button>
                        <button class="btn-next" onclick="goNext()" id="btn-5-next" disabled>Continue →</button>
                    </div>
                </div>

                <!-- ════ STEP 6: Extra Notes + Clear Options ════ -->
                <div class="step" data-step="6">
                    <span class="step-icon">💬</span>
                    <h2 class="step-title">Final details</h2>
                    <p class="step-subtitle">Customize further and choose what to do with existing content.</p>

                    <div class="form-group">
                        <label class="form-label">Describe exactly what you want</label>
                        <textarea class="form-input" id="ans-notes" placeholder="Be specific! e.g:
- Add a #partnerships channel in a Business category
- Staff roles should be red shades only
- Include a #counting game channel
- I want a separate category for each game I play (Valorant, CS2, Minecraft)
- Make role names in Arabic" maxlength="800" style="min-height:130px;"></textarea>
                        <div style="font-size:11px;color:var(--muted);margin-top:6px;">The more specific you are, the
                            better the result ✨</div>
                    </div>

                    <div style="margin-bottom:28px;">
                        <label class="form-label" style="margin-bottom:10px;">Existing server content</label>
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <div class="feature-toggle" onclick="toggleClear('channels',this)"
                                id="clear-channels-toggle">
                                <div class="feature-icon-wrap">🗑️</div>
                                <div class="feature-text">
                                    <div class="feature-name">Delete existing channels</div>
                                    <div class="feature-hint">Remove all current channels before creating new ones</div>
                                </div>
                                <div class="toggle-pill"></div>
                            </div>
                            <div class="feature-toggle" onclick="toggleClear('roles',this)" id="clear-roles-toggle">
                                <div class="feature-icon-wrap">🗑️</div>
                                <div class="feature-text">
                                    <div class="feature-name">Delete existing roles</div>
                                    <div class="feature-hint">Remove all current roles before creating new ones</div>
                                </div>
                                <div class="toggle-pill"></div>
                            </div>
                        </div>
                    </div>

                    <div class="wizard-nav">
                        <button class="btn-back" onclick="goBack()">← Back</button>
                        <button class="btn-next" onclick="startGeneration()">
                            🪄 Generate with AI
                        </button>
                    </div>
                </div>

                <!-- ════ STEP 7: AI Generating ════ -->
                <div class="step" data-step="7">
                    <div class="ai-loading-wrap">
                        <div class="ai-orb">
                            <div class="ai-orb-ring"></div>
                            <div class="ai-orb-ring"></div>
                            <div class="ai-orb-inner">✨</div>
                        </div>
                        <div class="ai-status">AI is building your server</div>
                        <div class="ai-substatus" id="ai-status-text">
                            Analyzing your preferences<span class="ai-dots"><span class="ai-dot"></span><span
                                    class="ai-dot"></span><span class="ai-dot"></span></span>
                        </div>
                        <div
                            style="margin-top:28px;height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden;">
                            <div id="ai-progress"
                                style="height:100%;background:linear-gradient(90deg,var(--purple),var(--purple-light));width:0%;transition:width 0.5s ease;border-radius:2px;">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ════ STEP 8: Preview & Edit ════ -->
                <div class="step" data-step="8">
                    <span class="step-icon">👀</span>
                    <h2 class="step-title">Preview your server</h2>
                    <p class="step-subtitle">Click any name to edit it before applying.</p>

                    <div class="preview-split" id="preview-content">
                        <div class="preview-section">
                            <h4>📁 Channels</h4>
                            <div id="preview-channels"></div>
                        </div>
                        <div class="preview-section">
                            <h4>🛡️ Roles</h4>
                            <div id="preview-roles"></div>
                        </div>
                    </div>

                    <!-- Debug panel - shows raw AI JSON -->
                    <div class="debug-panel">
                        <div class="debug-header" onclick="toggleDebug()">
                            <span>🔍 Debug — Raw AI Output</span>
                            <span id="debug-toggle-label">Show</span>
                        </div>
                        <pre class="debug-body" id="debug-body"></pre>
                    </div>

                    <div class="wizard-nav" style="margin-top:16px;">
                        <button class="btn-back" onclick="goBack()">← Regenerate</button>
                        <button class="btn-next" onclick="startApply()">
                            🚀 Apply to Server
                        </button>
                    </div>
                </div>

                <!-- ════ STEP 9: Applying ════ -->
                <div class="step" data-step="9">
                    <span class="step-icon">⚙️</span>
                    <h2 class="step-title">Building your server</h2>
                    <p class="step-subtitle">Creating channels and roles on Discord...</p>

                    <div class="apply-progress-bar">
                        <div class="apply-progress-fill" id="apply-progress" style="width:0%"></div>
                    </div>

                    <div class="apply-log" id="apply-log"></div>
                </div>

                <!-- ════ STEP 10: Done! ════ -->
                <div class="step" data-step="10">
                    <div class="done-celebration">
                        <div class="done-icon-wrap">🎉</div>
                        <h2 class="step-title" style="margin-bottom:8px;">Server is ready!</h2>
                        <p class="step-subtitle">Your server structure has been created successfully.</p>

                        <div class="done-stats" id="done-stats">
                            <div class="done-stat">
                                <div class="done-stat-num" id="stat-channels">0</div>
                                <div class="done-stat-label">Channels</div>
                            </div>
                            <div class="done-stat">
                                <div class="done-stat-num" id="stat-categories">0</div>
                                <div class="done-stat-label">Categories</div>
                            </div>
                            <div class="done-stat">
                                <div class="done-stat-num" id="stat-roles">0</div>
                                <div class="done-stat-label">Roles</div>
                            </div>
                        </div>

                        <button class="btn-go-dashboard" onclick="goToDashboard()">
                            Go to Dashboard →
                        </button>
                    </div>
                </div>

            </div><!-- /.wizard-inner -->
        </div><!-- /.wizard-card -->
    </div><!-- /.wizard-wrap -->

    <div class="confetti-container" id="confetti-container"></div>

    <script>
        var GUILD_ID = '<%= guild.id %>';
        var TOTAL_STEPS = 10;
        var currentStep = 1;
        var GUILD_NAME = <%- JSON.stringify(guild.name) %>;
        var answers = {
            serverName: GUILD_NAME,
            description: '',
            serverType: '',
            channelStyle: '',
            features: ['welcome', 'logs'],
            roleComplexity: '',
            extraNotes: ''
        };
        var generatedStructure = null;
        var editableStructure = null;
        var clearOptions = { channels: false, roles: false };

        // ── Init ──
        buildDots();
        updateProgress();

        function buildDots() {
            var container = document.getElementById('step-dots');
            container.innerHTML = '';
            var nonUISteps = [1, 2, 3, 4, 5, 6, 8]; // visible steps with dots
            nonUISteps.forEach(function (s) {
                var d = document.createElement('div');
                d.className = 'step-dot' + (s === currentStep ? ' active' : (s < currentStep ? ' done' : ''));
                d.id = 'dot-' + s;
                container.appendChild(d);
            });
        }

        function updateProgress() {
            var pct = ((currentStep - 1) / (TOTAL_STEPS - 1)) * 100;
            document.getElementById('progress-fill').style.width = pct + '%';
            buildDots();
        }

        function showStep(n) {
            document.querySelectorAll('.step').forEach(function (s) { s.classList.remove('active'); });
            var target = document.querySelector('[data-step="' + n + '"]');
            if (target) target.classList.add('active');
            currentStep = n;
            updateProgress();
        }

        function goNext() {
            // Collect answers from current step
            if (currentStep === 1) {
                answers.serverName = document.getElementById('ans-name').value.trim() || answers.serverName;
                answers.description = document.getElementById('ans-description').value.trim();
            }
            if (currentStep === 6) { startGeneration(); return; }
            showStep(currentStep + 1);
        }

        function goBack() {
            if (currentStep === 8) { showStep(6); return; } // back from preview goes to notes
            if (currentStep <= 1) return;
            showStep(currentStep - 1);
        }

        // ── Option selection ──
        function selectOption(group, value, el) {
            // Remove selected from siblings
            el.closest('.options-grid').querySelectorAll('.option-card').forEach(function (c) {
                c.classList.remove('selected');
            });
            el.classList.add('selected');
            answers[group === 'type' ? 'serverType' : group === 'style' ? 'channelStyle' : group === 'roles' ? 'roleComplexity' : group] = value;

            // Enable next button
            var nextBtn = document.getElementById('btn-' + currentStep + '-next');
            if (nextBtn) nextBtn.disabled = false;
        }

        // ── Feature toggles ──
        function toggleFeature(feature, el) {
            el.classList.toggle('on');
            if (el.classList.contains('on')) {
                if (answers.features.indexOf(feature) === -1) answers.features.push(feature);
            } else {
                answers.features = answers.features.filter(function (f) { return f !== feature; });
            }
        }

        // ── Clear options toggles ──
        function toggleClear(type, el) {
            el.classList.toggle('on');
            clearOptions[type] = el.classList.contains('on');
        }

        // ── AI Generation ──
        var aiStatusMessages = [
            'Analyzing your preferences',
            'Designing channel structure',
            'Crafting role hierarchy',
            'Optimizing for your server type',
            'Adding finishing touches',
            'Almost done'
        ];
        var aiStatusIdx = 0;
        var aiStatusTimer;
        var aiProgressTimer;

        function startGeneration() {
            answers.extraNotes = document.getElementById('ans-notes').value.trim();
            showStep(7);

            // Animate progress + status messages
            var pct = 0;
            aiProgressTimer = setInterval(function () {
                pct = Math.min(pct + (Math.random() * 8), 85);
                document.getElementById('ai-progress').style.width = pct + '%';
            }, 400);

            aiStatusTimer = setInterval(function () {
                aiStatusIdx = (aiStatusIdx + 1) % aiStatusMessages.length;
                document.getElementById('ai-status-text').innerHTML = aiStatusMessages[aiStatusIdx] +
                    '<span class="ai-dots"><span class="ai-dot"></span><span class="ai-dot"></span><span class="ai-dot"></span></span>';
            }, 2500);

            // Call API
            fetch('/wizard/' + GUILD_ID + '/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ answers: answers })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    clearInterval(aiProgressTimer);
                    clearInterval(aiStatusTimer);

                    if (!data.success) {
                        alert('AI generation failed: ' + data.error);
                        showStep(6);
                        return;
                    }

                    document.getElementById('ai-progress').style.width = '100%';
                    generatedStructure = data.structure;
                    editableStructure = JSON.parse(JSON.stringify(data.structure)); // deep copy

                    // Show debug JSON
                    document.getElementById('debug-body').textContent = JSON.stringify(data.structure, null, 2);

                    setTimeout(function () {
                        renderPreview();
                        showStep(8);
                    }, 600);
                })
                .catch(function (err) {
                    clearInterval(aiProgressTimer);
                    clearInterval(aiStatusTimer);
                    alert('Network error. Check console.');
                    console.error(err);
                    showStep(6);
                });
        }

        // ── Render Preview ──
        function renderPreview() {
            var s = editableStructure;

            // Channels
            var chEl = document.getElementById('preview-channels');
            chEl.innerHTML = '';
            (s.categories || []).forEach(function (cat) {
                var catDiv = document.createElement('div');
                catDiv.className = 'preview-cat';
                catDiv.contentEditable = 'true';
                catDiv.title = 'Click to edit';
                catDiv.textContent = '▸ ' + cat.name;
                catDiv.addEventListener('blur', function () { cat.name = this.textContent.replace(/^▸\s*/, '').trim(); });
                chEl.appendChild(catDiv);

                (cat.channels || []).forEach(function (ch) {
                    var chDiv = document.createElement('div');
                    chDiv.className = 'preview-ch';
                    chDiv.innerHTML = '<span>' + (ch.type === 2 ? '🔊' : '#') + '</span><input value="' + escHtml(ch.name) + '" oninput="ch.name=this.value">';
                    chEl.appendChild(chDiv);
                });
            });

            // Roles
            var rolesEl = document.getElementById('preview-roles');
            rolesEl.innerHTML = '';
            (s.roles || []).forEach(function (role) {
                var r = document.createElement('div');
                r.className = 'preview-role';
                r.innerHTML = '<div class="role-dot" style="background:' + (role.color || '#5865F2') + '"></div>' +
                    '<input value="' + escHtml(role.name) + '" style="background:none;border:none;outline:none;color:inherit;font-family:inherit;font-size:12px;width:100%;" oninput="role.name=this.value">';
                rolesEl.appendChild(r);
            });
        }

        function escHtml(t) {
            var d = document.createElement('div'); d.textContent = t; return d.innerHTML;
        }

        // ── Debug panel ──
        function toggleDebug() {
            var body = document.getElementById('debug-body');
            var label = document.getElementById('debug-toggle-label');
            body.classList.toggle('show');
            label.textContent = body.classList.contains('show') ? 'Hide' : 'Show';
        }

        // ── Apply ──
        function startApply() {
            showStep(9);
            var log = document.getElementById('apply-log');
            var progressBar = document.getElementById('apply-progress');
            log.innerHTML = '<div class="apply-log-item pending">⏳ Connecting to Discord...</div>';

            fetch('/wizard/' + GUILD_ID + '/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ structure: editableStructure, clearExisting: clearOptions })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var items = data.log || [];
                    log.innerHTML = '';
                    var done = 0;

                    function showNext() {
                        if (done >= items.length) {
                            progressBar.style.width = '100%';
                            setTimeout(function () { showDone(data); }, 800);
                            return;
                        }
                        var item = items[done++];
                        var el = document.createElement('div');
                        el.className = 'apply-log-item ' + (item.success ? 'ok' : 'fail');
                        var icon = item.type === 'category' ? '📁' : item.type === 'role' ? '🛡️' : '#';
                        el.textContent = (item.success ? '✓' : '✕') + ' ' + icon + ' ' + item.name;
                        if (!item.success && item.error) el.textContent += ' — ' + item.error;
                        log.appendChild(el);
                        log.scrollTop = log.scrollHeight;
                        progressBar.style.width = ((done / items.length) * 95) + '%';
                        setTimeout(showNext, 120);
                    }

                    showNext();
                })
                .catch(function (err) {
                    log.innerHTML = '<div class="apply-log-item fail">✕ Failed: ' + err.message + '</div>';
                });
        }

        function showDone(data) {
            var s = editableStructure;
            var totalChannels = (s.categories || []).reduce(function (a, c) { return a + (c.channels || []).length; }, 0);
            var totalCats = (s.categories || []).length;
            var totalRoles = (s.roles || []).length;

            document.getElementById('stat-channels').textContent = totalChannels;
            document.getElementById('stat-categories').textContent = totalCats;
            document.getElementById('stat-roles').textContent = totalRoles;

            showStep(10);
            launchConfetti();
        }

        function goToDashboard() {
            window.location.href = '/dashboard/' + GUILD_ID + '/channels';
        }

        // ── Skip ──
        function skipWizard() {
            if (!confirm('Skip the setup wizard? You can always set up your server manually from the dashboard.')) return;
            fetch('/wizard/' + GUILD_ID + '/skip', { method: 'POST' })
                .then(function () { window.location.href = '/dashboard/' + GUILD_ID + '/channels'; });
        }

        // ── Confetti ──
        function launchConfetti() {
            var container = document.getElementById('confetti-container');
            var colors = ['#7c3aed', '#a78bfa', '#10b981', '#fbbf24', '#f43f5e', '#60a5fa'];
            for (var i = 0; i < 60; i++) {
                (function (i) {
                    setTimeout(function () {
                        var piece = document.createElement('div');
                        piece.className = 'confetti-piece';
                        piece.style.left = Math.random() * 100 + 'vw';
                        piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                        piece.style.animationDuration = (2 + Math.random() * 2) + 's';
                        piece.style.animationDelay = Math.random() * 0.5 + 's';
                        piece.style.width = (6 + Math.random() * 6) + 'px';
                        piece.style.height = (6 + Math.random() * 6) + 'px';
                        piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                        container.appendChild(piece);
                        setTimeout(function () { piece.remove(); }, 4000);
                    }, i * 30);
                })(i);
            }
        }
    </script>
</body>

</html>