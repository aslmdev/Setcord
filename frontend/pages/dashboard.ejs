<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setcord - Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #1a1a2e;
            color: #fff;
        }
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
            background: #16213e;
            border-bottom: 1px solid #0f3460;
        }
        .navbar h2 { margin: 0; }
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-info img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
        }
        .logout-btn {
            padding: 6px 15px;
            background: #e94560;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            font-size: 14px;
            margin-left: 15px;
        }
        .logout-btn:hover { background: #c73e54; }
        .container {
            max-width: 800px;
            margin: 30px auto;
            padding: 0 20px;
        }
        .section {
            background: #16213e;
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 20px;
        }
        .section h3 { margin-top: 0; }
        .server-list {
            list-style: none;
            padding: 0;
            margin: 15px 0;
        }
        .server-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            background: #0f3460;
            border-radius: 6px;
            margin-bottom: 8px;
        }
        .server-name {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .server-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #5865F2;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 16px;
        }
        .server-icon img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
        }
        .bot-status {
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 3px;
        }
        .bot-yes { background: #2ecc7140; color: #2ecc71; }
        .bot-no { background: #e74c3c40; color: #e74c3c; }
        .create-btn {
            padding: 8px 18px;
            background: #5865F2;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            margin-left: 10px;
        }
        .create-btn:hover { background: #4752C4; }
        .create-btn:disabled {
            background: #555;
            cursor: not-allowed;
        }
        .invite-btn {
            padding: 8px 18px;
            background: #2ecc71;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            font-size: 14px;
            margin-left: 10px;
        }
        .invite-btn:hover { background: #27ae60; }
        .message {
            padding: 10px 15px;
            border-radius: 5px;
            margin-top: 15px;
            display: none;
        }
        .message.success { display: block; background: #2ecc7130; color: #2ecc71; border: 1px solid #2ecc71; }
        .message.error { display: block; background: #e74c3c30; color: #e74c3c; border: 1px solid #e74c3c; }
        .loading { color: #aaa; }
    </style>
</head>
<body>
    <nav class="navbar">
        <h2>Setcord</h2>
        <div class="user-info">
            <% if (user.avatar) { %>
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="Avatar">
            <% } %>
            <span><%= user.globalName || user.username %></span>
            <a href="/auth/logout" class="logout-btn">Logout</a>
        </div>
    </nav>

    <div class="container">
        <div class="section">
            <h3>Your Servers (Admin)</h3>
            <p class="loading" id="loading">Loading servers...</p>
            <ul class="server-list" id="server-list"></ul>
            <div class="message" id="message"></div>
        </div>
    </div>

    <script>
        const CLIENT_ID = '<%= clientId %>';
        const messageEl = document.getElementById('message');
        const loadingEl = document.getElementById('loading');
        const serverListEl = document.getElementById('server-list');

        function showMessage(text, type) {
            messageEl.textContent = text;
            messageEl.className = 'message ' + type;
        }

        function clearMessage() {
            messageEl.className = 'message';
            messageEl.textContent = '';
        }

        async function loadServers() {
            try {
                const res = await fetch('/api/servers');
                const data = await res.json();

                loadingEl.style.display = 'none';

                if (!data.success) {
                    showMessage(data.error || 'Failed to load servers', 'error');
                    return;
                }

                if (data.servers.length === 0) {
                    serverListEl.innerHTML = '<li style="color:#aaa;">No servers found where you have Admin permission.</li>';
                    return;
                }

                data.servers.forEach((server) => {
                    const li = document.createElement('li');
                    li.className = 'server-item';

                    const iconHtml = server.icon
                        ? `<img src="https://cdn.discordapp.com/icons/${server.id}/${server.icon}.png?size=64" alt="">`
                        : server.name.charAt(0).toUpperCase();

                    let actionsHtml = '';
                    if (server.botPresent) {
                        actionsHtml = `
                            <div>
                                <span class="bot-status bot-yes">Bot Active</span>
                                <button class="create-btn" onclick="createChannel('${server.id}', this)">Create #setcord</button>
                            </div>
                        `;
                    } else {
                        actionsHtml = `
                            <div>
                                <span class="bot-status bot-no">No Bot</span>
                                <a href="https://discord.com/oauth2/authorize?client_id=${CLIENT_ID}&scope=bot&permissions=8&guild_id=${server.id}" 
                                   target="_blank" class="invite-btn">Invite Bot</a>
                            </div>
                        `;
                    }

                    li.innerHTML = `
                        <div class="server-name">
                            <div class="server-icon">${iconHtml}</div>
                            <span>${escapeHtml(server.name)}</span>
                        </div>
                        ${actionsHtml}
                    `;

                    serverListEl.appendChild(li);
                });
            } catch (err) {
                loadingEl.style.display = 'none';
                showMessage('Failed to load servers. Please refresh.', 'error');
                console.error(err);
            }
        }

        async function createChannel(guildId, btn) {
            clearMessage();
            btn.disabled = true;
            btn.textContent = 'Creating...';

            try {
                const res = await fetch('/api/create-channel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ guildId }),
                });

                const data = await res.json();

                if (data.success) {
                    showMessage(data.message, 'success');
                    btn.textContent = 'Done ✓';
                } else {
                    showMessage(data.error, 'error');
                    btn.disabled = false;
                    btn.textContent = 'Create #setcord';
                }
            } catch (err) {
                showMessage('Request failed. Please try again.', 'error');
                btn.disabled = false;
                btn.textContent = 'Create #setcord';
                console.error(err);
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Load servers on page load
        loadServers();
    </script>
</body>
</html>
