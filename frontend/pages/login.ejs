<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setcord — Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #080812;
            --card: #0f0f22;
            --purple: #7c3aed;
            --purple-light: #a78bfa;
            --border: #1c1c3a;
            --text: #e8e8f0;
            --muted: #64748b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* background glow */
        body::before {
            content: '';
            position: fixed;
            top: -300px; left: 50%;
            transform: translateX(-50%);
            width: 700px; height: 700px;
            background: radial-gradient(circle, rgba(124,58,237,0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .login-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 48px 44px;
            width: 100%;
            max-width: 420px;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(0,0,0,0.6);
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--purple), transparent);
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .logo span { color: var(--purple-light); }

        .tagline {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 40px;
        }

        .discord-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 14px 24px;
            background: #5865F2;
            color: #fff;
            text-decoration: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .discord-btn:hover {
            background: #4752c4;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(88,101,242,0.4);
        }

        .discord-btn svg { flex-shrink: 0; }

        .error-box {
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 13px;
            color: #f87171;
            margin-bottom: 20px;
            text-align: left;
        }

        .footer-note {
            margin-top: 28px;
            font-size: 12px;
            color: var(--muted);
            line-height: 1.6;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">Set<span>cord</span></div>
        <p class="tagline">Discord server management dashboard</p>

        <% if (error) { %>
        <div class="error-box">
            <% if (error === 'auth_failed') { %>
                Authentication failed. Please try again.
            <% } else if (error === 'no_code') { %>
                No authorization code received. Please try again.
            <% } else { %>
                An error occurred: <%= error %>
            <% } %>
        </div>
        <% } %>

        <a href="/auth/discord" class="discord-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.012.127.073.248.183.347 2.063 1.518 4.064 2.44 6.028 3.048a.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.048.077.077 0 0 0 .032-.027c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
            Continue with Discord
        </a>

        <p class="footer-note">
            You'll be redirected to Discord to authorize.<br>
            Only servers where you have Administrator permission will appear.
        </p>
    </div>
</body>
</html>
