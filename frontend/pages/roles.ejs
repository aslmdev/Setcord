<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setcord - Roles Manager</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="app-layout">
        <%- include('../components/sidebar', { guild, activePage: 'roles' }) %>

        <main class="main-content">
            <div class="page-header">
                <h1>Roles Manager</h1>
                <p>Create, edit, and organize your server roles.</p>
            </div>

            <div class="two-col">
                <!-- LEFT: Roles List -->
                <div>
                    <div class="card">
                        <div class="card-header">
                            <h3>Roles</h3>
                            <button class="btn btn-primary btn-sm" onclick="toggleCreateForm()">+ New Role</button>
                        </div>

                        <!-- Create Role Form (hidden) -->
                        <div class="inline-form" id="create-form" style="display:none; margin-bottom: 16px;">
                            <div class="form-group" style="margin-bottom:8px;">
                                <label>Role Name</label>
                                <input type="text" class="form-input" id="new-role-name" placeholder="e.g. Moderator">
                            </div>
                            <div class="form-group" style="margin-bottom:8px;">
                                <label>Role Color</label>
                                <div class="color-palette" id="new-color-palette"></div>
                                <input type="text" class="form-input" id="new-role-color" placeholder="#7C3AED" style="margin-top:8px; max-width:120px;">
                            </div>
                            <div class="form-actions">
                                <button class="btn btn-ghost btn-sm" onclick="toggleCreateForm()">Cancel</button>
                                <button class="btn btn-primary btn-sm" onclick="createRole()">Create Role</button>
                            </div>
                        </div>

                        <!-- Roles List -->
                        <div id="roles-list">
                            <div class="loading-spinner">Loading roles...</div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Role Editor -->
                <div>
                    <div class="card" id="editor-card" style="display:none;">
                        <div class="card-header">
                            <h3>Edit Role</h3>
                        </div>

                        <div class="form-group">
                            <label>Role Name</label>
                            <input type="text" class="form-input" id="edit-role-name" placeholder="Role name">
                        </div>

                        <div class="form-group">
                            <label>Role Color</label>
                            <div class="color-palette" id="edit-color-palette"></div>
                            <input type="text" class="form-input" id="edit-role-color" placeholder="#7C3AED" style="margin-top:8px; max-width:120px;">
                        </div>

                        <div style="display:flex; gap:8px; margin-top:20px;">
                            <button class="btn btn-ghost" onclick="discardEdit()">Discard Changes</button>
                            <button class="btn btn-primary" onclick="saveRole()">Save Role</button>
                        </div>

                        <div style="margin-top:20px; padding-top:16px; border-top:1px solid var(--border-color);">
                            <button class="btn btn-danger btn-sm" onclick="deleteSelectedRole()">Delete Role</button>
                        </div>

                        <input type="hidden" id="edit-role-id">
                    </div>

                    <!-- No role selected -->
                    <div class="card" id="no-selection">
                        <div class="empty-state">
                            <p>👈 Select a role to edit</p>
                            <p>Or create a new one</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast" style="display:none;"></div>

    <script>
        const GUILD_ID = '<%= guild.id %>';
        let selectedRoleId = null;

        const PRESET_COLORS = [
            '#e74c3c', '#e67e22', '#f1c40f', '#2ecc71', '#1abc9c',
            '#3498db', '#9b59b6', '#e91e63', '#7c3aed', '#6d28d9',
            '#ec4899', '#f97316', '#84cc16', '#06b6d4', '#8b5cf6',
            '#ef4444', '#22c55e', '#0ea5e9',
        ];

        function showToast(msg, type) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = 'toast ' + type;
            t.style.display = 'block';
            setTimeout(() => { t.style.display = 'none'; }, 3000);
        }

        function escapeHtml(text) {
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        // ---- RENDER COLOR PALETTES ----
        function renderPalette(containerId, inputId) {
            const container = document.getElementById(containerId);
            container.innerHTML = '';
            PRESET_COLORS.forEach((color) => {
                const swatch = document.createElement('div');
                swatch.className = 'color-swatch';
                swatch.style.background = color;
                swatch.setAttribute('data-color', color);
                swatch.onclick = () => {
                    document.getElementById(inputId).value = color;
                    // Update selected state
                    container.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
                    swatch.classList.add('selected');
                };
                container.appendChild(swatch);
            });
        }

        renderPalette('new-color-palette', 'new-role-color');
        renderPalette('edit-color-palette', 'edit-role-color');

        // ---- LOAD ROLES ----
        async function loadRoles() {
            const container = document.getElementById('roles-list');

            try {
                const res = await fetch(`/api/${GUILD_ID}/roles`);
                const data = await res.json();

                if (!data.success) {
                    container.innerHTML = `<div class="empty-state"><p>${data.error}</p></div>`;
                    return;
                }

                if (data.roles.length === 0) {
                    container.innerHTML = '<div class="empty-state"><p>No roles found. Create one!</p></div>';
                    return;
                }

                let html = '';
                data.roles.forEach((role) => {
                    const isSelected = role.id === selectedRoleId;
                    html += `
                        <div class="role-item ${isSelected ? 'selected' : ''}" onclick="selectRole('${role.id}', '${escapeHtml(role.name)}', '${role.color}')">
                            <div class="role-info">
                                <span class="role-dot" style="background:${role.color}"></span>
                                <span class="role-name">${escapeHtml(role.name)}</span>
                            </div>
                            <span class="role-count">${role.memberCount}</span>
                        </div>`;
                });

                container.innerHTML = html;
            } catch (err) {
                container.innerHTML = '<div class="empty-state"><p>Failed to load roles.</p></div>';
                console.error(err);
            }
        }

        // ---- SELECT ROLE FOR EDITING ----
        function selectRole(roleId, name, color) {
            selectedRoleId = roleId;

            document.getElementById('editor-card').style.display = 'block';
            document.getElementById('no-selection').style.display = 'none';
            document.getElementById('edit-role-id').value = roleId;
            document.getElementById('edit-role-name').value = name;
            document.getElementById('edit-role-color').value = color;

            // Update selected state in palette
            const palette = document.getElementById('edit-color-palette');
            palette.querySelectorAll('.color-swatch').forEach((s) => {
                s.classList.toggle('selected', s.getAttribute('data-color') === color);
            });

            // Update selected state in list
            document.querySelectorAll('.role-item').forEach((el) => el.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }

        function discardEdit() {
            selectedRoleId = null;
            document.getElementById('editor-card').style.display = 'none';
            document.getElementById('no-selection').style.display = 'block';
            document.querySelectorAll('.role-item').forEach((el) => el.classList.remove('selected'));
        }

        // ---- SAVE ROLE ----
        async function saveRole() {
            const roleId = document.getElementById('edit-role-id').value;
            const name = document.getElementById('edit-role-name').value.trim();
            const color = document.getElementById('edit-role-color').value.trim();

            if (!name) { showToast('Enter a role name', 'error'); return; }

            const updates = { name };
            if (color && /^#[0-9a-fA-F]{6}$/.test(color)) {
                updates.color = color;
            }

            try {
                const res = await fetch(`/api/${GUILD_ID}/roles/${roleId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updates),
                });
                const data = await res.json();

                if (data.success) {
                    showToast('Role updated!', 'success');
                    loadRoles();
                } else {
                    showToast(data.error, 'error');
                }
            } catch (err) {
                showToast('Failed to save role', 'error');
            }
        }

        // ---- CREATE ROLE ----
        function toggleCreateForm() {
            const form = document.getElementById('create-form');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }

        async function createRole() {
            const name = document.getElementById('new-role-name').value.trim();
            const color = document.getElementById('new-role-color').value.trim();

            if (!name) { showToast('Enter a role name', 'error'); return; }

            const body = { name };
            if (color && /^#[0-9a-fA-F]{6}$/.test(color)) {
                body.color = color;
            }

            try {
                const res = await fetch(`/api/${GUILD_ID}/roles`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const data = await res.json();

                if (data.success) {
                    showToast(`Role "${data.role.name}" created!`, 'success');
                    document.getElementById('new-role-name').value = '';
                    document.getElementById('new-role-color').value = '';
                    document.getElementById('new-color-palette').querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
                    toggleCreateForm();
                    loadRoles();
                } else {
                    showToast(data.error, 'error');
                }
            } catch (err) {
                showToast('Failed to create role', 'error');
            }
        }

        // ---- DELETE ROLE ----
        async function deleteSelectedRole() {
            const roleId = document.getElementById('edit-role-id').value;
            if (!roleId) return;
            if (!confirm('Are you sure you want to delete this role?')) return;

            try {
                const res = await fetch(`/api/${GUILD_ID}/roles/${roleId}`, { method: 'DELETE' });
                const data = await res.json();

                if (data.success) {
                    showToast('Role deleted', 'success');
                    discardEdit();
                    loadRoles();
                } else {
                    showToast(data.error, 'error');
                }
            } catch (err) {
                showToast('Failed to delete role', 'error');
            }
        }

        // Load on start
        loadRoles();
    </script>
</body>
</html>
