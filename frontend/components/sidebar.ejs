<!-- Sidebar Component -->
<aside class="sidebar">
    <div class="sidebar-header">
        <% if (guild.icon) { %>
            <img src="<%= guild.icon %>" alt="">
            <% } else { %>
                <div class="server-initial">
                    <%= guild.name.charAt(0).toUpperCase() %>
                </div>
                <% } %>
                    <div class="sidebar-header-text">
                        <h3>
                            <%= guild.name %>
                        </h3>
                        <span>Setcord Panel</span>
                    </div>
    </div>

    <!-- Test Mode Banner (injected by JS when active) -->
    <div id="test-mode-sidebar-banner" style="display:none;
        background: rgba(245,158,11,0.1);
        border-bottom: 1px solid rgba(245,158,11,0.2);
        padding: 7px 14px;
        font-size: 11px;
        color: #fbbf24;
        display: none;
        align-items: center;
        gap: 6px;">
        <span>⚡</span> Test Mode Active
    </div>

    <nav class="sidebar-nav">
        <a href="/dashboard/<%= guild.id %>/channels" class="<%= activePage === 'channels' ? 'active' : '' %>">
            <span class="nav-icon">💬</span> Channels
        </a>
        <a href="/dashboard/<%= guild.id %>/roles" class="<%= activePage === 'roles' ? 'active' : '' %>">
            <span class="nav-icon">🛡️</span> Roles
        </a>
        <a href="/dashboard/<%= guild.id %>/setup" class="<%= activePage === 'setup' ? 'active' : '' %>">
            <span class="nav-icon">⚡</span> Fast Setup
        </a>
        <a href="/dashboard/<%= guild.id %>/settings" class="nav-link <%= activePage === 'settings' ? 'active' : '' %>">
            ⚙️ Settings
        </a>
        <div style="height:1px; background:var(--border-color); margin: 8px 12px;"></div>
        <a href="#" class="disabled">
            <span class="nav-icon">📊</span> Analytics
        </a>
        <a href="#" class="disabled">
            <span class="nav-icon">📋</span> Templates
        </a>
        <a href="#" class="disabled">
            <span class="nav-icon">🤖</span> AI Setup
        </a>
    </nav>

    <div class="sidebar-bottom">
        <div style="display:flex;align-items:center;gap:8px;padding:8px 0 12px 0;border-bottom:1px solid var(--border-color);margin-bottom:8px;">
            <div style="width:30px;height:30px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--accent-purple);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;">
                <% if (typeof user !== 'undefined' && user && user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.<%= user.avatar.startsWith('a_') ? 'gif' : 'webp' %>?size=64" alt="" style="width:100%;height:100%;object-fit:cover;">
                <% } else if (typeof user !== 'undefined' && user) { %>
                    <%= (user.globalName || user.username || '?').charAt(0).toUpperCase() %>
                <% } else { %>
                    ?
                <% } %>
            </div>
            <span style="font-size:12px;font-weight:600;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px;">
                <% if (typeof user !== 'undefined' && user) { %><%= user.globalName || user.username %><% } %>
            </span>
        </div>
        <a href="/servers">
            <span>←</span> Switch Server
        </a>
        <a href="/auth/logout" class="logout">
            <span>⏻</span> Logout
        </a>
    </div>
</aside>